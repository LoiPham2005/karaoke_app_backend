# Application
NODE_ENV=development
PORT=3001
APP_NAME=Karaoke API
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://karaoke:karaoke@localhost:5432/karaoke_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# YouTube Data API v3
YOUTUBE_API_KEY=AIzaSyD2yKmM---1X47GJd7dtyW1CA1DzzuqPl0

# LRCLIB
LRCLIB_API_URL=https://lrclib.net/api

# Email (Mailtrap for dev)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@karaoke.app

# Rate limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100
